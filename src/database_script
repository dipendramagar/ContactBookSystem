-- CONTACTS TABLE
CREATE TABLE contacts (
    cid INT PRIMARY KEY,
    name VARCHAR(100) NOT NULL,
    phone VARCHAR(20),
    email VARCHAR(100),
    address VARCHAR(200)
);
